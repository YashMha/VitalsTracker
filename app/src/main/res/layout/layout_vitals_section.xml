<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardSection"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvSectionTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333"/>

            <TextView
                android:id="@+id/tvOverall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#888"
            android:layout_marginBottom="10dp"/>

        <!-- Temperature Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:id="@+id/tvTemp" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="14sp"/>
            <TextView android:id="@+id/tvTempStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Pulse Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:id="@+id/tvPulse" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="14sp"/>
            <TextView android:id="@+id/tvPulseStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Respiratory Rate Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:id="@+id/tvRr" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="14sp"/>
            <TextView android:id="@+id/tvRrStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- SpO2 Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:id="@+id/tvSpo2" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="14sp"/>
            <TextView android:id="@+id/tvSpo2Status" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- BP Row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="4dp">
            <TextView android:id="@+id/tvBp" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="14sp"/>
            <TextView android:id="@+id/tvBpStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
