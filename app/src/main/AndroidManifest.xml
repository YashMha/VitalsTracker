<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VitalsTracker">

        <!-- Main Entry -->
        <activity
            android:name=".ui.patient.PatientListActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.patient.AddPatientActivity"
            android:label="Add Patient"
            android:parentActivityName=".ui.patient.PatientListActivity" />

        <activity
            android:name=".ui.patient.PatientDetailActivity"
            android:label="Patient Details"
            android:parentActivityName=".ui.patient.PatientListActivity" />

        <activity
            android:name=".ui.vitals.AddVitalsActivity"
            android:label="Record Vitals"
            android:parentActivityName=".ui.patient.PatientDetailActivity" />

        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:label="Dashboard"
            android:parentActivityName=".ui.patient.PatientDetailActivity" />

    </application>

</manifest>
